{
  "name": "4k-pos",
  "version": "5.4.66",
  "description": "4K POS - Sistema de Punto de Venta",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/4kpos/4kpos-app"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "bcryptjs": "^2.4.3"
  },
  "build": {
    "appId": "com.4kpos.app",
    "productName": "4K POS",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "4kpos",
        "repo": "4kpos-app",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "3082",
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "es_ES",
        "en_US"
      ],
      "warningsAsErrors": false
    },
    "files": [
      "**/*",
      "!dist/**",
      "!*.bat",
      "!*.cmd",
      "!*.ps1",
      "!*.vbs"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
